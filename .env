# Configuration de l'application
SECRET_KEY=changez-moi-en-production
DATABASE_URL=sqlite:///signatures.db

# Microsoft Graph API (pour synchronisation Outlook 365)
# Créez une application dans Azure AD : https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps
MS_CLIENT_ID=votre-client-id
MS_CLIENT_SECRET=votre-client-secret
MS_TENANT_ID=votre-tenant-id

# URL de base pour les bannières (utilisée dans les signatures)
BASE_URL=http://localhost:5000
